{
  "name": "wio-tag-formatter",
  "displayName": "wio-tag-formatter",
  "description": "Formatter for WIO code",
  "version": "0.0.1",
  "publisher": "wio-devlab",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:wio"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wio-tag-formatter.helloWorld",
        "title": "Hello World"
      }
    ],
    "languages": [
      {
        "id": "wio",
        "extensions": [
          ".wio"
        ],
        "aliases": [
          "WIO"
        ]
      }
    ],
    "configurationDefaults": {
      "[wio]": {
        "editor.formatOnSave": false
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
